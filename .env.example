# .env.example — copy to .env and fill in your values
# The app reads these via python-dotenv

#  Database 
# SQLite (default — zero setup, good for development)
DB_URL=sqlite:///nyc_taxi.db

# PostgreSQL alternative (uncomment and fill in if using Postgres)
# DB_URL=postgresql://username:password@localhost:5432/nyc_taxi

# Flask backend 
PORT=5000
FLASK_ENV=development       # set to "production" for deployment

# Data paths 
# Path to the raw parquet file (download from NYC TLC website)
PARQUET_PATH=data/raw/yellow_tripdata_2024-01.parquet

# Optional: batch size for database inserts (increase for faster loads)
BATCH_SIZE=10000
